# TLS-terminating reverse proxy for the backend (see docker-compose.yml's `caddy` service).
#
# MOODYBLUES_PUBLIC_HOST stays behind Cloudflare's proxy (orange cloud), so Caddy can't prove
# domain ownership to Let's Encrypt over the network -- Cloudflare's edge, not this box, answers
# on port 80/443 as far as the internet is concerned. Instead this uses a Cloudflare Origin
# Certificate (Cloudflare dashboard -> SSL/TLS -> Origin Server -> Create Certificate): it's
# trusted by Cloudflare's edge (which is all that ever talks to this box directly, as long as
# SSL/TLS mode is "Full (strict)"), not by browsers/Unity directly -- but they never see it, they
# only ever see Cloudflare's own edge certificate.
#
# See README.md's "HTTPS/TLS" section for the full setup steps. The two files below are NOT
# committed to git (see .gitignore) -- generate them yourself and place them on the server, next
# to this Caddyfile, in a `certs/` folder.
{$MOODYBLUES_PUBLIC_HOST} {
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key
	reverse_proxy backend:8765
}
